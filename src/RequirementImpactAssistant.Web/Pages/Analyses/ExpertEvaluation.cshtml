@page "/Analyses/{id:guid}/ExpertEvaluation"
@model RequirementImpactAssistant.Web.Pages.Analyses.ExpertEvaluationModel
@using RequirementImpactAssistant.Web.Domain.Enums
@using RequirementImpactAssistant.Web.Domain.Impact
@{
    ViewData["Title"] = Model.Analysis?.Title is null
        ? "Экспертная оценка"
        : $"Экспертная оценка - {Model.Analysis.Title}";
}

@if (Model.Analysis is not null)
{
    <section class="py-4">
        <div class="mb-4">
            <a asp-page="/Analyses/Details" asp-route-id="@Model.Analysis.Id" class="link-secondary">К деталям анализа</a>
        </div>

        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h2 mb-2">Экспертная оценка</h1>
                <p class="text-muted mb-0">@Model.Analysis.Title</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge text-bg-secondary">@AnalysisUiText.AnalysisStatusLabel(Model.Analysis.Status)</span>
                <span class="badge text-bg-info">@AnalysisUiText.AiResultStatusLabel(Model.Analysis.AiResultStatus)</span>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.ExpertEvaluationMessage))
        {
            <div class="alert alert-success" role="status">@Model.ExpertEvaluationMessage</div>
        }

        @{
            var contextSummary = Model.Analysis.ContextSummary;
        }

        <section class="border rounded p-3 mb-4" aria-labelledby="expert-evaluation-context-heading">
            <div class="mb-3">
                <h2 id="expert-evaluation-context-heading" class="h4 mb-2">Контекст для экспертной оценки</h2>
                <p class="text-muted mb-0">
                    Сводка ниже построена только из сохраненного результата анализа и входных данных карточки. Она не запускает повторный анализ и не является экспертной оценкой.
                </p>
            </div>

            <div class="row g-4">
                <div class="col-lg-6">
                    <section class="h-100">
                        <h3 class="h5 mb-3">Входные данные</h3>
                        <dl class="row mb-0">
                            <dt class="col-sm-4">@AnalysisUiText.ProjectRequestTypeFieldLabel</dt>
                            <dd class="col-sm-8">@AnalysisUiText.ProjectRequestTypeLabel(contextSummary.ProjectRequestType)</dd>

                            <dt class="col-sm-4">@AnalysisUiText.ChangeSourceLabel</dt>
                            <dd class="col-sm-8">@contextSummary.ChangeSource</dd>

                            <dt class="col-sm-4">@AnalysisUiText.OriginalDescriptionLabel</dt>
                            <dd class="col-sm-8 text-break">@contextSummary.OriginalDescription</dd>

                            <dt class="col-sm-4">@AnalysisUiText.ProjectRequestLabel</dt>
                            <dd class="col-sm-8 text-break">@contextSummary.ProjectRequest</dd>

                            <dt class="col-sm-4">@AnalysisUiText.SituationDescriptionLabel</dt>
                            <dd class="col-sm-8 text-break">@contextSummary.SituationDescription</dd>
                        </dl>
                    </section>
                </div>

                <div class="col-lg-6">
                    <section class="h-100">
                        <h3 class="h5 mb-3">Основания и ограничения</h3>
                        <dl class="row mb-0">
                            <dt class="col-sm-5">Режим анализа</dt>
                            <dd class="col-sm-7">@AnalysisUiText.AnalysisModeLabel(contextSummary.AnalysisMode)</dd>

                            <dt class="col-sm-5">Retrieved context state</dt>
                            <dd class="col-sm-7">@AnalysisUiText.RetrievedContextStateLabel(contextSummary.RetrievedContextState)</dd>

                            <dt class="col-sm-5">Пояснение</dt>
                            <dd class="col-sm-7">@AnalysisUiText.RetrievedContextStateDescription(contextSummary.RetrievedContextState)</dd>

                            <dt class="col-sm-5">Ручной контекст</dt>
                            <dd class="col-sm-7">@AnalysisUiText.ManualContextForwardingLabel(contextSummary.ManualContextForwardedToExternalAiOrRag)</dd>

                            <dt class="col-sm-5">Предупреждения</dt>
                            <dd class="col-sm-7">@contextSummary.Warnings.Count</dd>

                            <dt class="col-sm-5">Limitation notes</dt>
                            <dd class="col-sm-7">@contextSummary.LimitationNoteCount</dd>

                            @if (!string.IsNullOrWhiteSpace(contextSummary.EngineName))
                            {
                                <dt class="col-sm-5">Механизм</dt>
                                <dd class="col-sm-7">@contextSummary.EngineName</dd>
                            }

                            @if (!string.IsNullOrWhiteSpace(contextSummary.ProviderName))
                            {
                                <dt class="col-sm-5">Provider</dt>
                                <dd class="col-sm-7">@contextSummary.ProviderName</dd>
                            }

                            @if (!string.IsNullOrWhiteSpace(contextSummary.AdapterName))
                            {
                                <dt class="col-sm-5">Adapter</dt>
                                <dd class="col-sm-7">@contextSummary.AdapterName</dd>
                            }

                            @if (!string.IsNullOrWhiteSpace(contextSummary.ModelWorkflowProfileName))
                            {
                                <dt class="col-sm-5">Профиль</dt>
                                <dd class="col-sm-7">@contextSummary.ModelWorkflowProfileName</dd>
                            }
                        </dl>
                    </section>
                </div>
            </div>

            <section class="border-top pt-3 mt-3">
                <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                    <div>
                        <h3 class="h5 mb-1">Preliminary impact map</h3>
                        <p class="text-muted mb-0">
                            Сохраненная карта влияния содержит @contextSummary.ImpactItemCount элементов и используется как preliminary analytical material.
                        </p>
                    </div>
                    <span class="badge text-bg-secondary">Read-only</span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <article class="border rounded p-3 h-100">
                            <div class="small text-muted mb-1">@AnalysisUiText.ImpactMapItemTypeLabel(contextSummary.ChangeSummary.ItemType)</div>
                            <h4 class="h6 mb-2">@contextSummary.ChangeSummary.Title</h4>
                            <p class="mb-2 text-break">@contextSummary.ChangeSummary.Description</p>
                            <div class="small text-muted">@AnalysisUiText.ImpactSeverityLabel(contextSummary.ChangeSummary.Severity)</div>
                        </article>
                    </div>
                    <div class="col-md-6">
                        <article class="border rounded p-3 h-100">
                            <div class="small text-muted mb-1">@AnalysisUiText.ImpactMapItemTypeLabel(contextSummary.PreliminaryAssessment.ItemType)</div>
                            <h4 class="h6 mb-2">@contextSummary.PreliminaryAssessment.Title</h4>
                            <p class="mb-2 text-break">@contextSummary.PreliminaryAssessment.Description</p>
                            <div class="small text-muted">@AnalysisUiText.ImpactSeverityLabel(contextSummary.PreliminaryAssessment.Severity)</div>
                        </article>
                    </div>
                </div>
            </section>

            <section class="border-top pt-3 mt-3">
                <h3 class="h5 mb-3">Retrieved context</h3>
                @if (contextSummary.RetrievedContextItems.Count == 0)
                {
                    @if (contextSummary.IsDirectLlmWithoutRetrievedContext)
                    {
                        <div class="alert alert-info mb-0" role="status">
                            Для режима Direct LLM отдельный retrieved context не создается и не подменяется искусственными источниками.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0" role="status">
                            Сохраненных элементов retrieved context нет; эксперт видит только состояние @AnalysisUiText.RetrievedContextStateLabel(contextSummary.RetrievedContextState).
                        </div>
                    }
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Источник</th>
                                    <th scope="col">Completeness</th>
                                    <th scope="col">Rank/score</th>
                                    <th scope="col">Reference</th>
                                    <th scope="col">Limitation</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in contextSummary.RetrievedContextItems)
                                {
                                    <tr>
                                        <td class="text-break">
                                            <div class="fw-medium">@item.SourceTitle</div>
                                            @if (!string.IsNullOrWhiteSpace(item.SourceId))
                                            {
                                                <div class="small text-muted"><code>@item.SourceId</code></div>
                                            }
                                        </td>
                                        <td>@AnalysisUiText.RetrievedContextItemCompletenessLabel(item.Completeness)</td>
                                        <td>
                                            @(item.Rank is null ? "-" : $"Rank {item.Rank}")
                                            @if (item.Score is not null)
                                            {
                                                <span class="text-muted small">/ @item.Score.Value.ToString("0.###")</span>
                                            }
                                        </td>
                                        <td class="text-break">
                                            @(item.UrlOrReference ?? item.ExternalReference ?? item.FragmentId ?? "-")
                                        </td>
                                        <td class="text-break">
                                            @(string.IsNullOrWhiteSpace(item.WarningOrLimitationNote) ? "-" : item.WarningOrLimitationNote)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            @if (contextSummary.HasWarningsOrLimitations)
            {
                <section class="border-top pt-3 mt-3">
                    <h3 class="h5 mb-3">Warnings / limitations</h3>
                    @if (contextSummary.Warnings.Count > 0)
                    {
                        <div class="alert alert-warning" role="status">
                            <h4 class="h6">Предупреждения результата</h4>
                            <ul class="mb-0">
                                @foreach (var warning in contextSummary.Warnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (contextSummary.LimitationNoteCount > 0)
                    {
                        <ul class="mb-0">
                            @foreach (var note in contextSummary.RetrievedContextItems
                                .Where(item => !string.IsNullOrWhiteSpace(item.WarningOrLimitationNote))
                                .Select(item => item.WarningOrLimitationNote))
                            {
                                <li>@note</li>
                            }
                        </ul>
                    }
                </section>
            }
        </section>

        <form method="post" class="d-grid gap-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <section>
                <h2 class="h4 mb-3">Оценки элементов карты влияния</h2>

                @{
                    var itemIndex = 0;
                }

                <div class="d-grid gap-4">
                    @foreach (var impactSection in Model.Analysis.ImpactSections)
                    {
                        <section>
                            <h3 class="h5 mb-3">@impactSection.Title</h3>

                            @if (impactSection.Items.Count == 0)
                            {
                                <p class="text-muted mb-0">Нет элементов.</p>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th scope="col">Элемент</th>
                                                <th scope="col">Результат AI</th>
                                                <th scope="col">Оценка</th>
                                                <th scope="col">Комментарий</th>
                                                <th scope="col">Текст исправления</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in impactSection.Items)
                                            {
                                                <tr>
                                                    <td>
                                                        <input type="hidden" asp-for="Input.EvaluatedItems[itemIndex].TargetId" value="@item.Id" />
                                                        <div><code>@item.Id</code></div>
                                                        <div class="small text-muted">@AnalysisUiText.ImpactMapItemTypeLabel(item.ItemType) / @AnalysisUiText.ImpactSeverityLabel(item.Severity)</div>
                                                    </td>
                                                    <td class="text-break">
                                                        <div class="fw-medium">@item.Title</div>
                                                        <div>@item.Description</div>
                                                        @if (!string.IsNullOrWhiteSpace(item.Notes))
                                                        {
                                                            <div class="small text-muted">@item.Notes</div>
                                                        }
                                                    </td>
                                                    <td>
                                                        <select asp-for="Input.EvaluatedItems[itemIndex].Mark"
                                                                asp-items="AnalysisUiText.ExpertMarkItems()"
                                                                class="form-select form-select-sm"></select>
                                                        <span asp-validation-for="Input.EvaluatedItems[itemIndex].Mark" class="text-danger small"></span>
                                                    </td>
                                                    <td>
                                                        <textarea asp-for="Input.EvaluatedItems[itemIndex].Comment"
                                                                  class="form-control form-control-sm"
                                                                  rows="3"></textarea>
                                                    </td>
                                                    <td>
                                                        <textarea asp-for="Input.EvaluatedItems[itemIndex].CorrectionText"
                                                                  class="form-control form-control-sm"
                                                                  rows="3"></textarea>
                                                        <span asp-validation-for="Input.EvaluatedItems[itemIndex].CorrectionText" class="text-danger small"></span>
                                                    </td>
                                                </tr>

                                                itemIndex++;
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </section>
                    }
                </div>
            </section>

            <section class="border-top pt-4">
                <h2 class="h4 mb-3">Пропущенные элементы</h2>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th scope="col">Тип</th>
                                <th scope="col">Название</th>
                                <th scope="col">Описание</th>
                                <th scope="col">Критичность</th>
                                <th scope="col">Комментарий</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var index = 0; index < Model.Input.MissedItems.Count; index++)
                            {
                                <tr>
                                    <td>
                                        <select asp-for="Input.MissedItems[index].ItemType"
                                                asp-items="AnalysisUiText.ImpactMapItemTypeItems()"
                                                class="form-select form-select-sm"></select>
                                    </td>
                                    <td>
                                        <input asp-for="Input.MissedItems[index].Title" class="form-control form-control-sm" />
                                        <span asp-validation-for="Input.MissedItems[index].Title" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <textarea asp-for="Input.MissedItems[index].Description" class="form-control form-control-sm" rows="3"></textarea>
                                        <span asp-validation-for="Input.MissedItems[index].Description" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <select asp-for="Input.MissedItems[index].Severity"
                                                asp-items="AnalysisUiText.ImpactSeverityItems()"
                                                class="form-select form-select-sm"></select>
                                    </td>
                                    <td>
                                        <textarea asp-for="Input.MissedItems[index].Comment" class="form-control form-control-sm" rows="3"></textarea>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="border-top pt-4">
                <h2 class="h4 mb-3">Дополнительные исправления</h2>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th scope="col">Целевой элемент</th>
                                <th scope="col">Тип</th>
                                <th scope="col">Текст</th>
                                <th scope="col">Комментарий</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var index = 0; index < Model.Input.Corrections.Count; index++)
                            {
                                <tr>
                                    <td>
                                        <select asp-for="Input.Corrections[index].TargetId" class="form-select form-select-sm">
                                            <option value="">Выберите цель</option>
                                            @foreach (var item in Model.Analysis.ImpactSections.SelectMany(section => section.Items))
                                            {
                                                <option value="@item.Id">@item.Id - @item.Title</option>
                                            }
                                        </select>
                                        <span asp-validation-for="Input.Corrections[index].TargetId" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <select asp-for="Input.Corrections[index].ItemType"
                                                asp-items="AnalysisUiText.ImpactMapItemTypeItems()"
                                                class="form-select form-select-sm"></select>
                                    </td>
                                    <td>
                                        <textarea asp-for="Input.Corrections[index].Text" class="form-control form-control-sm" rows="3"></textarea>
                                        <span asp-validation-for="Input.Corrections[index].Text" class="text-danger small"></span>
                                    </td>
                                    <td>
                                        <textarea asp-for="Input.Corrections[index].Comment" class="form-control form-control-sm" rows="3"></textarea>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="border-top pt-4">
                <h2 class="h4 mb-3">Общие оценки</h2>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Input.ContextSufficiency" class="form-label">Достаточность контекста</label>
                        <select asp-for="Input.ContextSufficiency"
                                asp-items="AnalysisUiText.ContextSufficiencyItems()"
                                class="form-select"></select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Input.ResultUsefulness" class="form-label">Полезность результата</label>
                        <select asp-for="Input.ResultUsefulness"
                                asp-items="AnalysisUiText.ResultUsefulnessItems()"
                                class="form-select"></select>
                    </div>
                </div>

                <div class="mt-3">
                    <label asp-for="Input.GeneralComment" class="form-label">Общий комментарий</label>
                    <textarea asp-for="Input.GeneralComment" class="form-control" rows="4"></textarea>
                </div>
            </section>

            <div class="d-flex justify-content-end gap-2 border-top pt-4">
                <a class="btn btn-outline-secondary"
                   asp-page="/Analyses/Details"
                   asp-route-id="@Model.Analysis.Id">
                    Отмена
                </a>
                <button type="submit" class="btn btn-primary">Сохранить экспертную оценку</button>
            </div>
        </form>
    </section>
}
