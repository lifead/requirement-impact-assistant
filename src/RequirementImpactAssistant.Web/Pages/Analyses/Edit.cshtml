@page "/Analyses/{id:guid}/Edit"
@model RequirementImpactAssistant.Web.Pages.Analyses.EditModel
@{
    ViewData["Title"] = "Редактирование анализа";
}

<section class="py-4">
    <div class="mb-4">
        <a asp-page="/Analyses/Details" asp-route-id="@Model.AnalysisId" class="link-secondary">К анализу</a>
    </div>

    <div class="mb-4">
        <h1 class="h2 mb-2">Редактирование анализа</h1>
        <p class="text-muted mb-0">Обновите минимальные исходные поля сохраненного анализа.</p>
    </div>

    <form method="post" class="d-grid gap-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div>
            <label asp-for="Input.Title" class="form-label">Название</label>
            <input asp-for="Input.Title" class="form-control" />
            <span asp-validation-for="Input.Title" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.ProjectRequestType" class="form-label">@AnalysisUiText.ProjectRequestTypeFieldLabel</label>
            <select asp-for="Input.ProjectRequestType"
                    asp-items="AnalysisUiText.ProjectRequestTypeItems()"
                    class="form-select">
                <option value="">@AnalysisUiText.ProjectRequestTypePlaceholder</option>
            </select>
            <span asp-validation-for="Input.ProjectRequestType" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.OriginalDescription" class="form-label">@AnalysisUiText.OriginalDescriptionLabel</label>
            <textarea asp-for="Input.OriginalDescription" class="form-control" rows="4"></textarea>
            <div class="form-text">@AnalysisUiText.OriginalDescriptionHelpText</div>
            <span asp-validation-for="Input.OriginalDescription" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.ProjectRequest" class="form-label">@AnalysisUiText.ProjectRequestLabel</label>
            <textarea asp-for="Input.ProjectRequest" class="form-control" rows="4"></textarea>
            <div class="form-text">@AnalysisUiText.ProjectRequestHelpText</div>
            <span asp-validation-for="Input.ProjectRequest" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.SituationDescription" class="form-label">@AnalysisUiText.SituationDescriptionLabel</label>
            <textarea asp-for="Input.SituationDescription" class="form-control" rows="4"></textarea>
            <div class="form-text">@AnalysisUiText.SituationDescriptionHelpText</div>
            <span asp-validation-for="Input.SituationDescription" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.ChangeSource" class="form-label">@AnalysisUiText.ChangeSourceLabel</label>
            <input asp-for="Input.ChangeSource" class="form-control" />
            <div class="form-text">@AnalysisUiText.ChangeSourceHelpText</div>
            <span asp-validation-for="Input.ChangeSource" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Сохранить анализ</button>
            <a asp-page="/Analyses/Details" asp-route-id="@Model.AnalysisId" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</section>
