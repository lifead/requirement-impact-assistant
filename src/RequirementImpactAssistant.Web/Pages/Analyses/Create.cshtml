@page "/Analyses/New"
@model RequirementImpactAssistant.Web.Pages.Analyses.CreateModel
@{
    ViewData["Title"] = "Новый анализ";
}

<section class="py-4">
    <div class="mb-4">
        <a asp-page="/Analyses/Index" class="link-secondary">К списку сохраненных анализов</a>
    </div>

    <div class="mb-4">
        <h1 class="h2 mb-2">Новый анализ</h1>
        <p class="text-muted mb-0">Создайте минимальный набор исходных данных для последующего анализа.</p>
    </div>

    <form method="post" class="d-grid gap-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div>
            <label asp-for="Input.Title" class="form-label">Название</label>
            <input asp-for="Input.Title" class="form-control" />
            <span asp-validation-for="Input.Title" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.ProjectRequestType" class="form-label">Тип проектного запроса</label>
            <select asp-for="Input.ProjectRequestType"
                    asp-items="AnalysisUiText.ProjectRequestTypeItems()"
                    class="form-select">
                <option value="">Выберите тип проектного запроса</option>
            </select>
            <span asp-validation-for="Input.ProjectRequestType" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.OriginalDescription" class="form-label">Исходное описание</label>
            <textarea asp-for="Input.OriginalDescription" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Input.OriginalDescription" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.ProjectRequest" class="form-label">Проектный запрос</label>
            <textarea asp-for="Input.ProjectRequest" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Input.ProjectRequest" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.SituationDescription" class="form-label">Описание ситуации</label>
            <textarea asp-for="Input.SituationDescription" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Input.SituationDescription" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Input.ChangeSource" class="form-label">Источник изменения</label>
            <input asp-for="Input.ChangeSource" class="form-control" />
            <span asp-validation-for="Input.ChangeSource" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Сохранить анализ</button>
            <a asp-page="/Analyses/Index" class="btn btn-outline-secondary">Отмена</a>
        </div>
    </form>
</section>
