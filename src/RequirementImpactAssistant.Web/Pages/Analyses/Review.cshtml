@page "/Analyses/{id:guid}/Review"
@model RequirementImpactAssistant.Web.Pages.Analyses.ReviewModel
@{
    ViewData["Title"] = Model.Analysis is null
        ? "Review analysis input"
        : $"Review input: {Model.Analysis.Title}";
}

@if (Model.Analysis is not null)
{
    <section class="py-4">
        <div class="mb-4">
            <a asp-page="/Analyses/Details" asp-route-id="@Model.Analysis.Id" class="link-secondary">Back to analysis</a>
        </div>

        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h2 mb-2">Review input before LLM analysis</h1>
                <p class="text-muted mb-0">@Model.Analysis.Title</p>
            </div>
            <span class="badge text-bg-secondary">@Model.Analysis.Status</span>
        </div>

        <div class="alert alert-info" role="status">
            The quality of future intelligent analysis depends on the completeness of the project context.
        </div>

        @if (Model.Analysis.HasMinimumInput)
        {
            <div class="alert alert-success" role="status">
                Minimum analysis fields are filled. The analysis can continue without additional context fragments.
            </div>
        }
        else
        {
            <div class="alert alert-warning" role="status">
                Minimum analysis fields are not fully filled. Complete the source fields before continuing analysis.
            </div>
        }

        <dl class="row">
            <dt class="col-sm-3">Identifier</dt>
            <dd class="col-sm-9"><code>@Model.Analysis.Id</code></dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Analysis.Status</dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.Analysis.CreatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Updated</dt>
            <dd class="col-sm-9">@Model.Analysis.UpdatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Fixed</dt>
            <dd class="col-sm-9">@(Model.Analysis.FixedAt?.ToLocalTime().ToString("g") ?? "Not fixed")</dd>

            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Analysis.Title</dd>

            <dt class="col-sm-3">Original description</dt>
            <dd class="col-sm-9">@Model.Analysis.OriginalDescription</dd>

            <dt class="col-sm-3">Project request</dt>
            <dd class="col-sm-9">@Model.Analysis.ProjectRequest</dd>

            <dt class="col-sm-3">Situation description</dt>
            <dd class="col-sm-9">@Model.Analysis.SituationDescription</dd>

            <dt class="col-sm-3">Change source</dt>
            <dd class="col-sm-9">@Model.Analysis.ChangeSource</dd>
        </dl>
    </section>

    <section class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Context prepared for analysis</h2>
            <p class="text-muted mb-0">Read-only composition of manually added and uploaded context fragments.</p>
        </div>

        @if (Model.Analysis.ContextFragments.Count == 0)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">No additional context fragments are attached to this analysis.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Type</th>
                            <th scope="col">Source</th>
                            <th scope="col">File</th>
                            <th scope="col">Text</th>
                            <th scope="col">Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fragment in Model.Analysis.ContextFragments)
                        {
                            <tr>
                                <td>@fragment.Type</td>
                                <td>@fragment.Source</td>
                                <td>@(fragment.FileName ?? "-")</td>
                                <td class="text-break">@fragment.Text</td>
                                <td>@fragment.CreatedAt.ToLocalTime().ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}
