@page "/Analyses/{id:guid}/Review"
@model RequirementImpactAssistant.Web.Pages.Analyses.ReviewModel
@using RequirementImpactAssistant.Web.Domain.Enums
@{
    ViewData["Title"] = Model.Analysis is null
        ? "Проверка перед анализом"
        : $"Проверка перед анализом: {Model.Analysis.Title}";
    var selectedAnalysisModeName = string.IsNullOrWhiteSpace(Model.Input.AnalysisMode)
        ? nameof(AnalysisMode.DirectLlm)
        : Model.Input.AnalysisMode.Trim();
    var selectedAnalysisMode = selectedAnalysisModeName == nameof(AnalysisMode.ExternalRag)
        ? AnalysisMode.ExternalRag
        : AnalysisMode.DirectLlm;
}

@if (Model.Analysis is not null)
{
    <section class="py-4">
        <div class="mb-4">
            <a asp-page="/Analyses/Details" asp-route-id="@Model.Analysis.Id" class="link-secondary">К анализу</a>
        </div>

        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h2 mb-2">Проверка перед запуском предварительного анализа</h1>
                <p class="text-muted mb-0">@Model.Analysis.Title</p>
            </div>
            <span class="badge text-bg-secondary">@AnalysisUiText.AnalysisStatusLabel(Model.Analysis.Status)</span>
        </div>

        <div class="alert alert-info" role="status">
            Проверьте входные данные и контекст, добавленный человеком, перед запуском предварительного анализа.
            Экспертная оценка и заключение выполняются после получения предварительного результата.
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        @if (Model.Analysis.HasMinimumInput)
        {
            <div class="alert alert-success" role="status">
                Минимальные поля заполнены. Перед запуском проверьте проектное изменение, текущее состояние и ручной контекст.
            </div>

            <form method="post"
                  asp-page-handler="RunAnalysis"
                  asp-route-id="@Model.Analysis.Id"
                  class="mb-4">
                <fieldset class="mb-3">
                    <legend class="h5 mb-3">Как запускать предварительный анализ</legend>

                    <div class="alert alert-secondary mb-3" role="status">
                        <div class="fw-semibold">
                            Выбранный режим: @AnalysisUiText.AnalysisModeLabel(selectedAnalysisMode)
                        </div>
                        <div>@AnalysisUiText.AnalysisModeReviewDescription(selectedAnalysisMode)</div>
                    </div>

                    <div class="form-check mb-2">
                        <input class="form-check-input"
                               type="radio"
                               name="Input.AnalysisMode"
                               id="analysis-mode-direct-llm"
                               value="@nameof(AnalysisMode.DirectLlm)"
                               checked="@(selectedAnalysisMode == AnalysisMode.DirectLlm)" />
                        <label class="form-check-label" for="analysis-mode-direct-llm">
                            @AnalysisUiText.AnalysisModeLabel(AnalysisMode.DirectLlm)
                        </label>
                        <div class="form-text">
                            @AnalysisUiText.AnalysisModeReviewDescription(AnalysisMode.DirectLlm)
                        </div>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="radio"
                               name="Input.AnalysisMode"
                               id="analysis-mode-external-rag"
                               value="@nameof(AnalysisMode.ExternalRag)"
                               checked="@(selectedAnalysisMode == AnalysisMode.ExternalRag)" />
                        <label class="form-check-label" for="analysis-mode-external-rag">
                            @AnalysisUiText.AnalysisModeLabel(AnalysisMode.ExternalRag)
                        </label>
                        <div class="form-text">
                            @AnalysisUiText.AnalysisModeReviewDescription(AnalysisMode.ExternalRag)
                        </div>
                    </div>

                    <div class="form-text text-muted mt-2">
                        Страница проверки не выполняет сетевую проверку provider-ов и не требует секретов для просмотра.
                    </div>
                    <span asp-validation-for="Input.AnalysisMode" class="text-danger"></span>
                </fieldset>

                <button type="submit" class="btn btn-primary">Запустить предварительный анализ</button>
            </form>
        }
        else
        {
            <div class="alert alert-warning" role="status">
                Минимальные поля заполнены не полностью. Заполните исходные данные перед запуском предварительного анализа.
            </div>
        }

        <div class="mb-3">
            <h2 class="h4 mb-2">Входные данные для проверки</h2>
            <p class="text-muted mb-0">Эти сведения задают проектный запрос и используются как основа предварительного анализа.</p>
        </div>

        <dl class="row">
            <dt class="col-sm-3">Идентификатор</dt>
            <dd class="col-sm-9"><code>@Model.Analysis.Id</code></dd>

            <dt class="col-sm-3">Статус</dt>
            <dd class="col-sm-9">@AnalysisUiText.AnalysisStatusLabel(Model.Analysis.Status)</dd>

            <dt class="col-sm-3">Создано</dt>
            <dd class="col-sm-9">@Model.Analysis.CreatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Обновлено</dt>
            <dd class="col-sm-9">@Model.Analysis.UpdatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Зафиксировано</dt>
            <dd class="col-sm-9">@(Model.Analysis.FixedAt?.ToLocalTime().ToString("g") ?? "Не зафиксировано")</dd>

            <dt class="col-sm-3">Название</dt>
            <dd class="col-sm-9">@Model.Analysis.Title</dd>

            <dt class="col-sm-3">@AnalysisUiText.ProjectRequestTypeFieldLabel</dt>
            <dd class="col-sm-9">@AnalysisUiText.ProjectRequestTypeLabel(Model.Analysis.ProjectRequestType)</dd>

            <dt class="col-sm-3">@AnalysisUiText.OriginalDescriptionLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.OriginalDescription</dd>

            <dt class="col-sm-3">@AnalysisUiText.ProjectRequestLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.ProjectRequest</dd>

            <dt class="col-sm-3">@AnalysisUiText.SituationDescriptionLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.SituationDescription</dd>

            <dt class="col-sm-3">@AnalysisUiText.ChangeSourceLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.ChangeSource</dd>
        </dl>
    </section>

    <section class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Ручной контекст для проверки</h2>
            <p class="text-muted mb-0">Фрагменты, добавленные человеком к этому анализу перед запуском предварительного анализа.</p>
        </div>

        @if (Model.Analysis.ContextFragments.Count == 0)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">К этому анализу не прикреплены дополнительные фрагменты контекста.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Тип</th>
                            <th scope="col">Источник</th>
                            <th scope="col">Файл</th>
                            <th scope="col">Текст</th>
                            <th scope="col">Создано</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fragment in Model.Analysis.ContextFragments)
                        {
                            <tr>
                                <td>@AnalysisUiText.ContextFragmentTypeLabel(fragment.Type)</td>
                                <td>@fragment.Source</td>
                                <td>@(fragment.FileName ?? "-")</td>
                                <td class="text-break">@fragment.Text</td>
                                <td>@fragment.CreatedAt.ToLocalTime().ToString("g")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}
