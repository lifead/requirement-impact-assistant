@page "/Analyses/{id:guid}"
@model RequirementImpactAssistant.Web.Pages.Analyses.DetailsModel
@using RequirementImpactAssistant.Web.Domain.Enums
@{
    ViewData["Title"] = Model.Analysis?.Title ?? "Анализ";
}

@if (Model.Analysis is not null)
{
    <section class="py-4">
        <div class="mb-4">
            <a asp-page="/Analyses/Index" class="link-secondary">К списку сохраненных анализов</a>
        </div>

        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h2 mb-2">@Model.Analysis.Title</h1>
                <p class="text-muted mb-0">Обзор сохраненного анализа: входные данные, предварительный материал AI, человеческая проверка, заключение и сохраненный export.</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge text-bg-secondary">@AnalysisUiText.AnalysisStatusLabel(Model.Analysis.Status)</span>
                @if (Model.Analysis.AiAnalysisResult?.ImpactMap is not null &&
                    Model.Analysis.AiAnalysisResult.Status is AiAnalysisResultStatus.Completed or AiAnalysisResultStatus.CompletedWithWarnings)
                {
                    <a class="btn btn-outline-success btn-sm"
                       asp-page="/Analyses/ExpertEvaluation"
                       asp-route-id="@Model.Analysis.Id">
                        Экспертная оценка
                    </a>
                }
                @if (Model.Analysis.HasExpertEvaluation)
                {
                    <a class="btn btn-outline-success btn-sm"
                       asp-page="/Analyses/ExpertConclusion"
                       asp-route-id="@Model.Analysis.Id">
                        Экспертное заключение
                    </a>
                }
                @if (Model.Analysis.ExpertConclusion is not null)
                {
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-page-handler="ExportJson"
                       asp-route-id="@Model.Analysis.Id">
                        Скачать JSON
                    </a>
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-page-handler="ExportMarkdown"
                       asp-route-id="@Model.Analysis.Id">
                        Скачать Markdown
                    </a>
                }
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="/Analyses/Review"
                   asp-route-id="@Model.Analysis.Id">
                    Проверить ввод
                </a>
                <a class="btn btn-outline-primary btn-sm"
                   asp-page="/Analyses/Edit"
                   asp-route-id="@Model.Analysis.Id">
                    Редактировать
                </a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.AnalysisRunMessage))
        {
            <div class="alert alert-info" role="status">@Model.AnalysisRunMessage</div>
        }

        <section class="border rounded p-3 mb-4" aria-labelledby="details-status-summary-heading">
            <div class="mb-3">
                <h2 id="details-status-summary-heading" class="h5 mb-1">Карта сохраненного анализа</h2>
                <p class="text-muted mb-0">Сводка показывает, какие части анализа уже сохранены и какое человеческое действие логически остается следующим.</p>
            </div>

            <div class="row g-3">
                @foreach (var summaryItem in Model.Analysis.StatusSummaryItems)
                {
                    <div class="col-md-6 col-xl-4">
                        <article class="h-100 border rounded p-3">
                            <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                                <h3 class="h6 mb-0">@summaryItem.Title</h3>
                                <span class="badge @summaryItem.BadgeCssClass">@summaryItem.StatusLabel</span>
                            </div>

                            <p class="text-muted small mb-3">@summaryItem.Description</p>

                            <div class="d-flex flex-wrap gap-2">
                                <a class="btn btn-outline-secondary btn-sm" href="#@summaryItem.Anchor">К разделу</a>
                                @foreach (var action in summaryItem.Actions)
                                {
                                    @if (!string.IsNullOrWhiteSpace(action.PageName))
                                    {
                                        <a class="btn btn-outline-secondary btn-sm"
                                           asp-page="@action.PageName"
                                           asp-route-id="@Model.Analysis.Id">
                                            @action.Label
                                        </a>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(action.HandlerName))
                                    {
                                        <a class="btn btn-outline-secondary btn-sm"
                                           asp-page-handler="@action.HandlerName"
                                           asp-route-id="@Model.Analysis.Id">
                                            @action.Label
                                        </a>
                                    }
                                }
                            </div>
                        </article>
                    </div>
                }
            </div>
        </section>

        <section class="mb-4" aria-labelledby="details-layers-heading">
            <div class="mb-3">
                <h2 id="details-layers-heading" class="h5 mb-1">Смысловые слои</h2>
                <p class="text-muted mb-0">Разделы ниже отделяют исходные данные, предварительный AI-материал, человеческие действия, контекст, export и диагностику.</p>
            </div>

            <div class="row g-3">
                <div class="col-md-6 col-xl-4">
                    <a class="d-block h-100 border rounded p-3 text-decoration-none text-body" href="#analysis-input">
                        <span class="badge text-bg-primary mb-2">Input</span>
                        <h3 class="h6">Входные данные</h3>
                        <p class="text-muted small mb-0">Что анализируется и какой запрос сохранен пользователем.</p>
                    </a>
                </div>
                <div class="col-md-6 col-xl-4">
                    <a class="d-block h-100 border rounded p-3 text-decoration-none text-body" href="#preliminary-result">
                        <span class="badge text-bg-secondary mb-2">Preliminary</span>
                        <h3 class="h6">Предварительный материал</h3>
                        <p class="text-muted small mb-0">AI-result и карта влияния как материал для проверки человеком.</p>
                    </a>
                </div>
                <div class="col-md-6 col-xl-4">
                    <a class="d-block h-100 border rounded p-3 text-decoration-none text-body" href="#expert-evaluation">
                        <span class="badge text-bg-success mb-2">Human</span>
                        <h3 class="h6">Экспертная работа</h3>
                        <p class="text-muted small mb-0">Оценка preliminary material и отдельное экспертное заключение.</p>
                    </a>
                </div>
                <div class="col-md-6 col-xl-4">
                    <a class="d-block h-100 border rounded p-3 text-decoration-none text-body" href="#manual-context">
                        <span class="badge text-bg-light text-dark mb-2">Manual context</span>
                        <h3 class="h6">Контекст пользователя</h3>
                        <p class="text-muted small mb-0">Материалы, явно добавленные человеком в карточку анализа.</p>
                    </a>
                </div>
                <div class="col-md-6 col-xl-4">
                    <a class="d-block h-100 border rounded p-3 text-decoration-none text-body" href="#retrieved-context">
                        <span class="badge text-bg-light text-dark mb-2">Retrieved context</span>
                        <h3 class="h6">Контекст external AI/RAG</h3>
                        <p class="text-muted small mb-0">Фрагменты или metadata, сохраненные от внешнего AI/RAG-контура.</p>
                    </a>
                </div>
                <div class="col-md-6 col-xl-4">
                    <a class="d-block h-100 border rounded p-3 text-decoration-none text-body" href="#diagnostics">
                        <span class="badge text-bg-warning mb-2">Diagnostics</span>
                        <h3 class="h6">Диагностика</h3>
                        <p class="text-muted small mb-0">Raw response, ошибки и снимок входа для проверки MVP.</p>
                    </a>
                </div>
            </div>
        </section>

        <section id="analysis-input" class="pt-2">
            <div class="mb-3">
                <h2 class="h4 mb-2">Входные данные</h2>
                <p class="text-muted mb-0">Сохраненный пользовательский ввод: текущее состояние, проектное изменение, причина и источник изменения.</p>
            </div>

        <dl class="row">
            <dt class="col-sm-3">Идентификатор</dt>
            <dd class="col-sm-9"><code>@Model.Analysis.Id</code></dd>

            <dt class="col-sm-3">Создано</dt>
            <dd class="col-sm-9">@Model.Analysis.CreatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Обновлено</dt>
            <dd class="col-sm-9">@Model.Analysis.UpdatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Зафиксировано</dt>
            <dd class="col-sm-9">@(Model.Analysis.FixedAt?.ToLocalTime().ToString("g") ?? "Не зафиксировано")</dd>

            <dt class="col-sm-3">@AnalysisUiText.ChangeSourceLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.ChangeSource</dd>

            <dt class="col-sm-3">@AnalysisUiText.ProjectRequestTypeFieldLabel</dt>
            <dd class="col-sm-9">@AnalysisUiText.ProjectRequestTypeLabel(Model.Analysis.ProjectRequestType)</dd>

            <dt class="col-sm-3">@AnalysisUiText.OriginalDescriptionLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.OriginalDescription</dd>

            <dt class="col-sm-3">@AnalysisUiText.ProjectRequestLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.ProjectRequest</dd>

            <dt class="col-sm-3">@AnalysisUiText.SituationDescriptionLabel</dt>
            <dd class="col-sm-9">@Model.Analysis.SituationDescription</dd>
        </dl>
        </section>
    </section>

    <section id="preliminary-result" class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Предварительный результат AI-анализа</h2>
            <p class="text-muted mb-0">AI/RAG/LLM формирует предварительный аналитический материал. Он требует человеческой проверки и не является экспертным заключением или управленческим решением.</p>
        </div>

        @if (Model.Analysis.AiAnalysisResult is null)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">Предварительный результат анализа еще не сформирован.</p>
            </div>
            <section id="grounds-limitations" class="mt-4">
                <h3 class="h5 mb-3">Основания и ограничения</h3>
                <div class="border rounded p-4 bg-light">
                    <p class="mb-0">Основания и ограничения будут доступны после формирования предварительного результата.</p>
                </div>
            </section>
        }
        else
        {
            var aiResult = Model.Analysis.AiAnalysisResult;

            <dl class="row">
                <dt class="col-sm-3">Статус результата</dt>
                <dd class="col-sm-9">@AnalysisUiText.AiResultStatusLabel(aiResult.Status)</dd>

                <dt class="col-sm-3">Сформировано</dt>
                <dd class="col-sm-9">@(aiResult.GeneratedAt?.ToLocalTime().ToString("g") ?? "Не сформировано")</dd>

                <dt class="col-sm-3">Версия промпта</dt>
                <dd class="col-sm-9">@aiResult.PromptVersion</dd>
            </dl>

            <section class="mb-4">
                <h3 class="h5 mb-3">Служебная сводка результата</h3>
                <p class="text-muted mb-3">
                    Эти сведения помогают понять режим анализа и воспроизводимость результата, но не заменяют карту влияния, экспертную оценку или экспертное заключение.
                </p>

                <dl class="row">
                    <dt class="col-sm-3">Режим анализа</dt>
                    <dd class="col-sm-9">@AnalysisUiText.AnalysisModeLabel(aiResult.Metadata.AnalysisMode)</dd>

                    @if (!string.IsNullOrWhiteSpace(aiResult.Metadata.EngineName))
                    {
                        <dt class="col-sm-3">Механизм</dt>
                        <dd class="col-sm-9">@aiResult.Metadata.EngineName</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(aiResult.Metadata.ProviderName))
                    {
                        <dt class="col-sm-3">Провайдер</dt>
                        <dd class="col-sm-9">@aiResult.Metadata.ProviderName</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(aiResult.Metadata.AdapterName))
                    {
                        <dt class="col-sm-3">Адаптер</dt>
                        <dd class="col-sm-9">@aiResult.Metadata.AdapterName</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(aiResult.Metadata.ModelWorkflowProfileName))
                    {
                        <dt class="col-sm-3">Профиль</dt>
                        <dd class="col-sm-9">@aiResult.Metadata.ModelWorkflowProfileName</dd>
                    }

                    <dt class="col-sm-3">Извлеченный контекст</dt>
                    <dd class="col-sm-9">@AnalysisUiText.RetrievedContextStateLabel(aiResult.Metadata.RetrievedContextState)</dd>

                    <dt class="col-sm-3">Ручной контекст</dt>
                    <dd class="col-sm-9">@AnalysisUiText.ManualContextForwardingLabel(aiResult.Metadata.ManualContextForwardedToExternalAiOrRag)</dd>
                </dl>

                @if (aiResult.Metadata.Warnings.Count > 0)
                {
                    <div class="alert alert-warning" role="status">
                        <h4 class="h6">Предупреждения и ограничения</h4>
                        <ul class="mb-0">
                            @foreach (var warning in aiResult.Metadata.Warnings)
                            {
                                <li>@warning</li>
                            }
                        </ul>
                    </div>
                }
            </section>

            <section id="grounds-limitations" class="mb-4">
                <h3 class="h5 mb-3">Основания и ограничения preliminary result</h3>
                <p class="text-muted mb-3">
                    Этот блок объясняет границы предварительного результата. Manual context и retrieved context показаны в отдельных разделах, чтобы не смешивать происхождение контекста.
                </p>

                <dl class="row">
                    <dt class="col-sm-3">Режим анализа</dt>
                    <dd class="col-sm-9">@AnalysisUiText.AnalysisModeLabel(aiResult.Metadata.AnalysisMode)</dd>

                    <dt class="col-sm-3">Состояние retrieved context</dt>
                    <dd class="col-sm-9">@AnalysisUiText.RetrievedContextStateLabel(aiResult.Metadata.RetrievedContextState)</dd>

                    <dt class="col-sm-3">Ограничение</dt>
                    <dd class="col-sm-9">@AnalysisUiText.RetrievedContextStateDescription(aiResult.Metadata.RetrievedContextState)</dd>
                </dl>
            </section>

            @if (aiResult.ImpactMap is null)
            {
                <div class="alert alert-warning" role="status">
                    Для этого результата не сохранена структурированная карта влияния. Проверьте предупреждения, ограничения и диагностический раздел ниже.
                </div>
            }
            else
            {
                <section id="impact-map" class="mb-4" aria-labelledby="impact-map-heading">
                    <div class="border rounded p-3 mb-3 bg-light">
                        <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                            <div>
                                <h3 id="impact-map-heading" class="h5 mb-1">Структурированная карта влияния</h3>
                                <p class="text-muted mb-0">
                                    Карта влияния является preliminary analytical material для экспертного рассмотрения человеком и не является экспертным заключением или управленческим решением.
                                </p>
                            </div>
                            <span class="badge text-bg-secondary">Preliminary material</span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3" aria-label="Сводка карты влияния">
                        @foreach (var summary in aiResult.ImpactMapSummaryCards)
                        {
                            <div class="col-md-4">
                                <article class="h-100 border rounded p-3">
                                    <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                                        <h4 class="h6 mb-0">@summary.Title</h4>
                                        <span class="badge text-bg-light text-dark">@summary.CountLabel</span>
                                    </div>
                                    <p class="text-muted small mb-0">@summary.Description</p>
                                </article>
                            </div>
                        }
                    </div>

                    <nav class="d-flex flex-wrap gap-2 mb-4" aria-label="Навигация по карте влияния">
                        @foreach (var impactGroup in aiResult.ImpactSectionGroups)
                        {
                            <a class="btn btn-outline-secondary btn-sm" href="#@impactGroup.Anchor">
                                @impactGroup.Title
                                <span class="text-muted">(@impactGroup.ItemCount)</span>
                            </a>
                        }
                    </nav>

                    <div class="d-grid gap-4">
                        @foreach (var impactGroup in aiResult.ImpactSectionGroups)
                        {
                            <section id="@impactGroup.Anchor" aria-labelledby="@($"{impactGroup.Anchor}-heading")">
                                <div class="mb-3">
                                    <h4 id="@($"{impactGroup.Anchor}-heading")" class="h5 mb-1">@impactGroup.Title</h4>
                                    <p class="text-muted mb-0">@impactGroup.Summary</p>
                                </div>

                                <div class="d-grid gap-3">
                                    @foreach (var impactSection in impactGroup.Sections)
                                    {
                                        <article id="@impactSection.Anchor" class="border rounded p-3">
                                            <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                                                <div>
                                                    <h5 class="h6 mb-1">@impactSection.Title</h5>
                                                    <p class="text-muted small mb-0">@impactSection.Summary</p>
                                                </div>
                                                <span class="badge text-bg-light text-dark">@impactSection.CountLabel</span>
                                            </div>

                                            @if (impactSection.Items.Count == 0)
                                            {
                                                <p class="text-muted mb-0">@impactSection.EmptyState</p>
                                            }
                                            else
                                            {
                                                <div class="row g-3">
                                                    @foreach (var item in impactSection.Items)
                                                    {
                                                        <div class="col-xl-6">
                                                            <article class="h-100 border rounded p-3">
                                                                <div class="d-flex align-items-start justify-content-between gap-3 mb-2">
                                                                    <div>
                                                                        <div class="small text-muted mb-1">
                                                                            <code>@item.Id</code>
                                                                            <span class="ms-2">@AnalysisUiText.ImpactMapItemTypeLabel(item.ItemType)</span>
                                                                        </div>
                                                                        <h6 class="mb-0">@(string.IsNullOrWhiteSpace(item.Title) ? "Без названия" : item.Title)</h6>
                                                                    </div>
                                                                    <span class="badge text-bg-secondary">@AnalysisUiText.ImpactSeverityLabel(item.Severity)</span>
                                                                </div>

                                                                @if (!string.IsNullOrWhiteSpace(item.Description))
                                                                {
                                                                    <p class="mb-2 text-break">@item.Description</p>
                                                                }
                                                                else
                                                                {
                                                                    <p class="text-muted mb-2">Описание не заполнено в предварительной карте.</p>
                                                                }

                                                                @if (!string.IsNullOrWhiteSpace(item.Notes))
                                                                {
                                                                    <p class="text-muted small mb-0 text-break">Примечания: @item.Notes</p>
                                                                }
                                                            </article>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </article>
                                    }
                                </div>
                            </section>
                        }
                    </div>
                </section>
            }
        }
    </section>

    <section id="retrieved-context" class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Retrieved context внешнего AI/RAG</h2>
            <p class="text-muted mb-0">
                RAG knowledge base остается внешней базой provider-а. В приложении сохраняются только фрагменты или metadata, которые provider вернул для конкретного анализа. Retrieved context не является экспертным доказательством сам по себе.
            </p>
        </div>

        @if (Model.Analysis.AiAnalysisResult is null)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">Retrieved context еще не может быть показан: предварительный результат анализа не сформирован.</p>
            </div>
        }
        else
        {
            var aiResult = Model.Analysis.AiAnalysisResult;

            <dl class="row">
                <dt class="col-sm-3">Режим анализа</dt>
                <dd class="col-sm-9">@AnalysisUiText.AnalysisModeLabel(aiResult.Metadata.AnalysisMode)</dd>

                <dt class="col-sm-3">Состояние</dt>
                <dd class="col-sm-9">@AnalysisUiText.RetrievedContextStateLabel(aiResult.Metadata.RetrievedContextState)</dd>

                <dt class="col-sm-3">Пояснение</dt>
                <dd class="col-sm-9">@AnalysisUiText.RetrievedContextStateDescription(aiResult.Metadata.RetrievedContextState)</dd>
            </dl>

            @if (aiResult.Metadata.RetrievedContextItems.Count == 0)
            {
                @if (aiResult.Metadata.AnalysisMode == AnalysisMode.ExternalRag)
                {
                    <div class="alert alert-warning" role="status">
                        Сохраненных элементов retrieved context нет; отсутствующий retrieved context не подменяется выдуманными источниками.
                    </div>
                }
                else
                {
                    <div class="alert alert-info" role="status">
                        Для режима Direct LLM отдельный retrieved context не создается и не сохраняется.
                    </div>
                }
            }
            else
            {
                <div class="d-grid gap-3">
                    @foreach (var item in aiResult.Metadata.RetrievedContextItems)
                    {
                        <article class="border rounded p-3">
                            <div class="d-flex align-items-start justify-content-between gap-3 mb-3">
                                <div>
                                    <h3 class="h6 mb-1">@item.SourceTitle</h3>
                                    <div class="text-muted small">
                                        @AnalysisUiText.RetrievedContextItemCompletenessLabel(item.Completeness)
                                    </div>
                                </div>
                                @if (item.Rank is not null)
                                {
                                    <span class="badge text-bg-secondary">Rank @item.Rank</span>
                                }
                            </div>

                            <dl class="row mb-3">
                                @if (!string.IsNullOrWhiteSpace(item.SourceId))
                                {
                                    <dt class="col-sm-3">Source ID</dt>
                                    <dd class="col-sm-9"><code>@item.SourceId</code></dd>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.ExternalReference))
                                {
                                    <dt class="col-sm-3">External reference</dt>
                                    <dd class="col-sm-9">@item.ExternalReference</dd>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.FragmentId))
                                {
                                    <dt class="col-sm-3">Fragment ID</dt>
                                    <dd class="col-sm-9"><code>@item.FragmentId</code></dd>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.UrlOrReference))
                                {
                                    <dt class="col-sm-3">URL/reference</dt>
                                    <dd class="col-sm-9 text-break">@item.UrlOrReference</dd>
                                }

                                @if (item.Score is not null)
                                {
                                    <dt class="col-sm-3">Score</dt>
                                    <dd class="col-sm-9">@item.Score.Value.ToString("0.###")</dd>
                                }
                            </dl>

                            @if (!string.IsNullOrWhiteSpace(item.Text))
                            {
                                <div class="mb-3">
                                    <h4 class="h6">Сохраненный текст</h4>
                                    <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap mb-0">@item.Text</pre>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(item.Excerpt))
                            {
                                <div class="mb-3">
                                    <h4 class="h6">Сохраненная выдержка</h4>
                                    <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap mb-0">@item.Excerpt</pre>
                                </div>
                            }

                            @if (string.IsNullOrWhiteSpace(item.Text) &&
                                string.IsNullOrWhiteSpace(item.Excerpt))
                            {
                                <p class="text-muted mb-3">Текст или выдержка источника не сохранены.</p>
                            }

                            @if (!string.IsNullOrWhiteSpace(item.WarningOrLimitationNote))
                            {
                                <div class="alert alert-warning mb-0" role="status">
                                    @item.WarningOrLimitationNote
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        }
    </section>

    <section id="expert-evaluation" class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Экспертная оценка</h2>
            <p class="text-muted mb-0">Человеческая проверка preliminary AI material: что эксперт подтвердил, исправил, дополнил или счел недостаточно обоснованным.</p>
        </div>

        <div class="border rounded p-4 bg-light">
            <p class="mb-0">
                @(Model.Analysis.HasExpertEvaluation
                    ? "Экспертная оценка зафиксирована."
                    : "Экспертная оценка еще не зафиксирована.")
            </p>
        </div>
    </section>

    <section id="expert-conclusion" class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Экспертное заключение</h2>
            <p class="text-muted mb-0">Итоговое человеческое заключение отдельно от preliminary AI material и экспертной оценки элементов.</p>
        </div>

        @if (Model.Analysis.ExpertConclusion is null)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">Экспертное заключение еще не зафиксировано.</p>
            </div>
        }
        else
        {
            <dl class="row">
                <dt class="col-sm-3">Тип</dt>
                <dd class="col-sm-9">@AnalysisUiText.ExpertConclusionTypeLabel(Model.Analysis.ExpertConclusion.ConclusionType)</dd>

                <dt class="col-sm-3">Зафиксировано</dt>
                <dd class="col-sm-9">@(Model.Analysis.ExpertConclusion.FixedAt?.ToLocalTime().ToString("g") ?? "Не зафиксировано")</dd>

                <dt class="col-sm-3">Комментарий</dt>
                <dd class="col-sm-9">@Model.Analysis.ExpertConclusion.Comment</dd>

                <dt class="col-sm-3">Обоснование</dt>
                <dd class="col-sm-9">@Model.Analysis.ExpertConclusion.Rationale</dd>
            </dl>
        }
    </section>

    <section id="export" class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Экспорт</h2>
            <p class="text-muted mb-0">Выгрузка сохраненного Markdown/JSON результата через существующие действия. Export не запускает повторный AI/RAG/LLM-анализ.</p>
        </div>

        @if (Model.Analysis.ExpertConclusion is null)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">Экспорт будет доступен после фиксации экспертного заключения.</p>
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page-handler="ExportJson"
                   asp-route-id="@Model.Analysis.Id">
                    Скачать JSON
                </a>
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page-handler="ExportMarkdown"
                   asp-route-id="@Model.Analysis.Id">
                    Скачать Markdown
                </a>
            </div>
        }
    </section>

    <section id="manual-context" class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Manual context пользователя</h2>
            <p class="text-muted mb-0">
                Это материалы, введенные пользователем в карточке анализа. Они не являются retrieved context и не представляют внешнюю RAG knowledge base provider-а.
            </p>
        </div>

        <form method="post"
              asp-page-handler="AddContextFragment"
              asp-route-id="@Model.Analysis.Id"
              class="d-grid gap-3 mb-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="ContextFragmentInput.Type" class="form-label">Тип</label>
                    <select asp-for="ContextFragmentInput.Type"
                            asp-items="AnalysisUiText.ContextFragmentTypeItems()"
                            class="form-select"></select>
                </div>
                <div class="col-md-8">
                    <label asp-for="ContextFragmentInput.Source" class="form-label">Источник</label>
                    <input asp-for="ContextFragmentInput.Source" class="form-control" />
                    <span asp-validation-for="ContextFragmentInput.Source" class="text-danger"></span>
                </div>
            </div>

            <div>
                <label asp-for="ContextFragmentInput.Text" class="form-label">Текст</label>
                <textarea asp-for="ContextFragmentInput.Text" class="form-control" rows="5"></textarea>
                <span asp-validation-for="ContextFragmentInput.Text" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn btn-primary">Добавить фрагмент</button>
            </div>
        </form>
        @if (Model.Analysis.ContextFragments.Count == 0)
        {
            <p class="text-muted mb-0">Manual context пока не введен пользователем.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Тип</th>
                            <th scope="col">Источник</th>
                            <th scope="col">Файл</th>
                            <th scope="col">Текст</th>
                            <th scope="col">Создано</th>
                            <th scope="col" class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fragment in Model.Analysis.ContextFragments)
                        {
                            <tr>
                                <td>@AnalysisUiText.ContextFragmentTypeLabel(fragment.Type)</td>
                                <td>@fragment.Source</td>
                                <td>@(fragment.FileName ?? "-")</td>
                                <td class="text-break">@fragment.Text</td>
                                <td>@fragment.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td class="text-end">
                                    <form method="post"
                                          asp-page-handler="DeleteContextFragment"
                                          asp-route-id="@Model.Analysis.Id"
                                          asp-route-fragmentId="@fragment.Id"
                                          class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Удалить</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section id="diagnostics" class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Диагностика и raw data</h2>
            <p class="text-muted mb-0">
                Вспомогательные сведения для проверки корректности MVP. Они не являются основным пользовательским маршрутом, preliminary result или экспертным заключением.
            </p>
        </div>

        @if (Model.Analysis.AiAnalysisResult is null)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">Диагностические данные AI-result будут доступны после формирования предварительного результата.</p>
            </div>
        }
        else
        {
            var aiResult = Model.Analysis.AiAnalysisResult;

            @if (!string.IsNullOrWhiteSpace(aiResult.ErrorMessage))
            {
                <div class="mb-4">
                    <h3 class="h5">Ошибка или diagnostic message</h3>
                    <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap">@aiResult.ErrorMessage</pre>
                </div>
            }

            <div class="mb-4">
                <h3 class="h5">Исходный ответ</h3>
                <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap">@aiResult.RawResponse</pre>
            </div>

            <div>
                <h3 class="h5">Снимок входных данных</h3>
                <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap">@aiResult.InputSnapshot</pre>
            </div>
        }
    </section>
}
