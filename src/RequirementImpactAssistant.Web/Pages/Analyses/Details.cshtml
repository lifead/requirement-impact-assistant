@page "/Analyses/{id:guid}"
@model RequirementImpactAssistant.Web.Pages.Analyses.DetailsModel
@using RequirementImpactAssistant.Web.Domain.Enums
@{
    ViewData["Title"] = Model.Analysis?.Title ?? "Анализ";
}

@if (Model.Analysis is not null)
{
    <section class="py-4">
        <div class="mb-4">
            <a asp-page="/Analyses/Index" class="link-secondary">К списку сохраненных анализов</a>
        </div>

        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h2 mb-2">@Model.Analysis.Title</h1>
                <p class="text-muted mb-0">Обзор сохраненного анализа.</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge text-bg-secondary">@AnalysisUiText.AnalysisStatusLabel(Model.Analysis.Status)</span>
                @if (Model.Analysis.AiAnalysisResult?.ImpactMap is not null &&
                    Model.Analysis.AiAnalysisResult.Status is AiAnalysisResultStatus.Completed or AiAnalysisResultStatus.CompletedWithWarnings)
                {
                    <a class="btn btn-outline-success btn-sm"
                       asp-page="/Analyses/ExpertEvaluation"
                       asp-route-id="@Model.Analysis.Id">
                        Экспертная оценка
                    </a>
                }
                @if (Model.Analysis.HasExpertEvaluation)
                {
                    <a class="btn btn-outline-success btn-sm"
                       asp-page="/Analyses/ExpertConclusion"
                       asp-route-id="@Model.Analysis.Id">
                        Экспертное заключение
                    </a>
                }
                @if (Model.Analysis.ExpertConclusion is not null)
                {
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-page-handler="ExportJson"
                       asp-route-id="@Model.Analysis.Id">
                        Скачать JSON
                    </a>
                    <a class="btn btn-outline-secondary btn-sm"
                       asp-page-handler="ExportMarkdown"
                       asp-route-id="@Model.Analysis.Id">
                        Скачать Markdown
                    </a>
                }
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="/Analyses/Review"
                   asp-route-id="@Model.Analysis.Id">
                    Проверить ввод
                </a>
                <a class="btn btn-outline-primary btn-sm"
                   asp-page="/Analyses/Edit"
                   asp-route-id="@Model.Analysis.Id">
                    Редактировать
                </a>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.AnalysisRunMessage))
        {
            <div class="alert alert-info" role="status">@Model.AnalysisRunMessage</div>
        }

        <dl class="row">
            <dt class="col-sm-3">Идентификатор</dt>
            <dd class="col-sm-9"><code>@Model.Analysis.Id</code></dd>

            <dt class="col-sm-3">Создано</dt>
            <dd class="col-sm-9">@Model.Analysis.CreatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Обновлено</dt>
            <dd class="col-sm-9">@Model.Analysis.UpdatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Зафиксировано</dt>
            <dd class="col-sm-9">@(Model.Analysis.FixedAt?.ToLocalTime().ToString("g") ?? "Не зафиксировано")</dd>

            <dt class="col-sm-3">Источник изменения</dt>
            <dd class="col-sm-9">@Model.Analysis.ChangeSource</dd>

            <dt class="col-sm-3">Исходное описание</dt>
            <dd class="col-sm-9">@Model.Analysis.OriginalDescription</dd>

            <dt class="col-sm-3">Проектный запрос</dt>
            <dd class="col-sm-9">@Model.Analysis.ProjectRequest</dd>

            <dt class="col-sm-3">Описание ситуации</dt>
            <dd class="col-sm-9">@Model.Analysis.SituationDescription</dd>
        </dl>
    </section>

    @if (Model.Analysis.ExpertConclusion is not null)
    {
        <section class="py-4 border-top">
            <div class="mb-4">
                <h2 class="h4 mb-2">Экспертное заключение</h2>
                <p class="text-muted mb-0">Итоговое заключение, зафиксированное экспертом-человеком.</p>
            </div>

            <dl class="row">
                <dt class="col-sm-3">Тип</dt>
                <dd class="col-sm-9">@AnalysisUiText.ExpertConclusionTypeLabel(Model.Analysis.ExpertConclusion.ConclusionType)</dd>

                <dt class="col-sm-3">Зафиксировано</dt>
                <dd class="col-sm-9">@(Model.Analysis.ExpertConclusion.FixedAt?.ToLocalTime().ToString("g") ?? "Не зафиксировано")</dd>

                <dt class="col-sm-3">Комментарий</dt>
                <dd class="col-sm-9">@Model.Analysis.ExpertConclusion.Comment</dd>

                <dt class="col-sm-3">Обоснование</dt>
                <dd class="col-sm-9">@Model.Analysis.ExpertConclusion.Rationale</dd>
            </dl>
        </section>
    }

    <section class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Предварительный результат AI-анализа</h2>
            <p class="text-muted mb-0">Этот материал является предварительным аналитическим материалом для экспертного рассмотрения человеком и не является управленческим решением.</p>
        </div>

        @if (Model.Analysis.AiAnalysisResult is null)
        {
            <div class="border rounded p-4 bg-light">
                <p class="mb-0">Предварительный результат анализа еще не сформирован.</p>
            </div>
        }
        else
        {
            var aiResult = Model.Analysis.AiAnalysisResult;

            <dl class="row">
                <dt class="col-sm-3">Статус результата</dt>
                <dd class="col-sm-9">@AnalysisUiText.AiResultStatusLabel(aiResult.Status)</dd>

                <dt class="col-sm-3">Сформировано</dt>
                <dd class="col-sm-9">@(aiResult.GeneratedAt?.ToLocalTime().ToString("g") ?? "Не сформировано")</dd>

                <dt class="col-sm-3">Механизм анализа</dt>
                <dd class="col-sm-9">@aiResult.EngineName</dd>

                <dt class="col-sm-3">Провайдер</dt>
                <dd class="col-sm-9">@aiResult.ProviderName</dd>

                <dt class="col-sm-3">Модель</dt>
                <dd class="col-sm-9">@aiResult.ModelName</dd>

                <dt class="col-sm-3">Версия промпта</dt>
                <dd class="col-sm-9">@aiResult.PromptVersion</dd>
            </dl>

            @if (aiResult.ImpactMap is null)
            {
                <div class="alert alert-warning" role="status">
                    Для этого результата не сохранена структурированная карта влияния. Проверьте диагностику и исходный ответ ниже.
                </div>
            }
            else
            {
                <div class="d-grid gap-4">
                    @foreach (var impactSection in aiResult.ImpactSections)
                    {
                        <section>
                            <h3 class="h5 mb-3">@impactSection.Title</h3>

                            @if (impactSection.Items.Count == 0)
                            {
                                <p class="text-muted mb-0">Нет элементов.</p>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle">
                                        <thead>
                                            <tr>
                                                <th scope="col">Идентификатор</th>
                                                <th scope="col">Тип</th>
                                                <th scope="col">Критичность</th>
                                                <th scope="col">Название</th>
                                                <th scope="col">Описание</th>
                                                <th scope="col">Примечания</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in impactSection.Items)
                                            {
                                                <tr>
                                                    <td><code>@item.Id</code></td>
                                                    <td>@AnalysisUiText.ImpactMapItemTypeLabel(item.ItemType)</td>
                                                    <td>@AnalysisUiText.ImpactSeverityLabel(item.Severity)</td>
                                                    <td>@item.Title</td>
                                                    <td class="text-break">@item.Description</td>
                                                    <td class="text-break">@item.Notes</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </section>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(aiResult.ErrorMessage))
            {
                <div class="mt-4">
                    <h3 class="h5">Диагностика</h3>
                    <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap">@aiResult.ErrorMessage</pre>
                </div>
            }

            <div class="mt-4">
                <h3 class="h5">Исходный ответ</h3>
                <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap">@aiResult.RawResponse</pre>
            </div>

            <div class="mt-4">
                <h3 class="h5">Снимок входных данных</h3>
                <pre class="border rounded bg-light p-3 text-break white-space-pre-wrap">@aiResult.InputSnapshot</pre>
            </div>
        }
    </section>

    <section class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Фрагменты контекста</h2>
            <p class="text-muted mb-0">Контекст, вручную добавленный к этому сохраненному анализу.</p>
        </div>

        <form method="post"
              asp-page-handler="AddContextFragment"
              asp-route-id="@Model.Analysis.Id"
              class="d-grid gap-3 mb-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="ContextFragmentInput.Type" class="form-label">Тип</label>
                    <select asp-for="ContextFragmentInput.Type"
                            asp-items="AnalysisUiText.ContextFragmentTypeItems()"
                            class="form-select"></select>
                </div>
                <div class="col-md-8">
                    <label asp-for="ContextFragmentInput.Source" class="form-label">Источник</label>
                    <input asp-for="ContextFragmentInput.Source" class="form-control" />
                    <span asp-validation-for="ContextFragmentInput.Source" class="text-danger"></span>
                </div>
            </div>

            <div>
                <label asp-for="ContextFragmentInput.Text" class="form-label">Текст</label>
                <textarea asp-for="ContextFragmentInput.Text" class="form-control" rows="5"></textarea>
                <span asp-validation-for="ContextFragmentInput.Text" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn btn-primary">Добавить фрагмент</button>
            </div>
        </form>

        <form method="post"
              enctype="multipart/form-data"
              asp-page-handler="UploadContextFragment"
              asp-route-id="@Model.Analysis.Id"
              class="d-grid gap-3 mb-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="UploadContextFragmentInput.Type" class="form-label">Тип загружаемого файла</label>
                    <select asp-for="UploadContextFragmentInput.Type"
                            asp-items="AnalysisUiText.ContextFragmentTypeItems()"
                            class="form-select"></select>
                </div>
                <div class="col-md-8">
                    <label asp-for="UploadContextFragmentInput.Source" class="form-label">Источник загружаемого файла</label>
                    <input asp-for="UploadContextFragmentInput.Source" class="form-control" />
                </div>
            </div>

            <div>
                <label asp-for="UploadContextFragmentInput.File" class="form-label">Файл Markdown, TXT или JSON</label>
                <input asp-for="UploadContextFragmentInput.File" class="form-control" type="file" accept=".md,.txt,.json" />
                <span asp-validation-for="UploadContextFragmentInput.File" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn btn-outline-primary">Загрузить файл</button>
            </div>
        </form>

        @if (Model.Analysis.ContextFragments.Count == 0)
        {
            <p class="text-muted mb-0">Фрагментов контекста пока нет.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Тип</th>
                            <th scope="col">Источник</th>
                            <th scope="col">Файл</th>
                            <th scope="col">Текст</th>
                            <th scope="col">Создано</th>
                            <th scope="col" class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fragment in Model.Analysis.ContextFragments)
                        {
                            <tr>
                                <td>@AnalysisUiText.ContextFragmentTypeLabel(fragment.Type)</td>
                                <td>@fragment.Source</td>
                                <td>@(fragment.FileName ?? "-")</td>
                                <td class="text-break">@fragment.Text</td>
                                <td>@fragment.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td class="text-end">
                                    <form method="post"
                                          asp-page-handler="DeleteContextFragment"
                                          asp-route-id="@Model.Analysis.Id"
                                          asp-route-fragmentId="@fragment.Id"
                                          class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Удалить</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}
