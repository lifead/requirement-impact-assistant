@page "/Analyses/{id:guid}"
@model RequirementImpactAssistant.Web.Pages.Analyses.DetailsModel
@using RequirementImpactAssistant.Web.Domain.Enums
@{
    ViewData["Title"] = Model.Analysis?.Title ?? "Analysis";
}

@if (Model.Analysis is not null)
{
    <section class="py-4">
        <div class="mb-4">
            <a asp-page="/Analyses/Index" class="link-secondary">Back to saved analyses</a>
        </div>

        <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
            <div>
                <h1 class="h2 mb-2">@Model.Analysis.Title</h1>
                <p class="text-muted mb-0">Saved analysis overview.</p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge text-bg-secondary">@Model.Analysis.Status</span>
                <a class="btn btn-outline-secondary btn-sm"
                   asp-page="/Analyses/Review"
                   asp-route-id="@Model.Analysis.Id">
                    Review input
                </a>
                <a class="btn btn-outline-primary btn-sm"
                   asp-page="/Analyses/Edit"
                   asp-route-id="@Model.Analysis.Id">
                    Edit
                </a>
            </div>
        </div>

        <dl class="row">
            <dt class="col-sm-3">Identifier</dt>
            <dd class="col-sm-9"><code>@Model.Analysis.Id</code></dd>

            <dt class="col-sm-3">Created</dt>
            <dd class="col-sm-9">@Model.Analysis.CreatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Updated</dt>
            <dd class="col-sm-9">@Model.Analysis.UpdatedAt.ToLocalTime().ToString("g")</dd>

            <dt class="col-sm-3">Fixed</dt>
            <dd class="col-sm-9">@(Model.Analysis.FixedAt?.ToLocalTime().ToString("g") ?? "Not fixed")</dd>

            <dt class="col-sm-3">Change source</dt>
            <dd class="col-sm-9">@Model.Analysis.ChangeSource</dd>

            <dt class="col-sm-3">Original description</dt>
            <dd class="col-sm-9">@Model.Analysis.OriginalDescription</dd>

            <dt class="col-sm-3">Project request</dt>
            <dd class="col-sm-9">@Model.Analysis.ProjectRequest</dd>

            <dt class="col-sm-3">Situation description</dt>
            <dd class="col-sm-9">@Model.Analysis.SituationDescription</dd>
        </dl>
    </section>

    <section class="py-4 border-top">
        <div class="mb-4">
            <h2 class="h4 mb-2">Context fragments</h2>
            <p class="text-muted mb-0">Manual context attached to this saved analysis.</p>
        </div>

        <form method="post"
              asp-page-handler="AddContextFragment"
              asp-route-id="@Model.Analysis.Id"
              class="d-grid gap-3 mb-4">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="ContextFragmentInput.Type" class="form-label">Type</label>
                    <select asp-for="ContextFragmentInput.Type"
                            asp-items="Html.GetEnumSelectList<ContextFragmentType>()"
                            class="form-select"></select>
                </div>
                <div class="col-md-8">
                    <label asp-for="ContextFragmentInput.Source" class="form-label">Source</label>
                    <input asp-for="ContextFragmentInput.Source" class="form-control" />
                    <span asp-validation-for="ContextFragmentInput.Source" class="text-danger"></span>
                </div>
            </div>

            <div>
                <label asp-for="ContextFragmentInput.Text" class="form-label">Text</label>
                <textarea asp-for="ContextFragmentInput.Text" class="form-control" rows="5"></textarea>
                <span asp-validation-for="ContextFragmentInput.Text" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn btn-primary">Add fragment</button>
            </div>
        </form>

        <form method="post"
              enctype="multipart/form-data"
              asp-page-handler="UploadContextFragment"
              asp-route-id="@Model.Analysis.Id"
              class="d-grid gap-3 mb-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="UploadContextFragmentInput.Type" class="form-label">Uploaded file type</label>
                    <select asp-for="UploadContextFragmentInput.Type"
                            asp-items="Html.GetEnumSelectList<ContextFragmentType>()"
                            class="form-select"></select>
                </div>
                <div class="col-md-8">
                    <label asp-for="UploadContextFragmentInput.Source" class="form-label">Uploaded file source</label>
                    <input asp-for="UploadContextFragmentInput.Source" class="form-control" />
                </div>
            </div>

            <div>
                <label asp-for="UploadContextFragmentInput.File" class="form-label">Markdown, TXT, or JSON file</label>
                <input asp-for="UploadContextFragmentInput.File" class="form-control" type="file" accept=".md,.txt,.json" />
                <span asp-validation-for="UploadContextFragmentInput.File" class="text-danger"></span>
            </div>

            <div>
                <button type="submit" class="btn btn-outline-primary">Upload file</button>
            </div>
        </form>

        @if (Model.Analysis.ContextFragments.Count == 0)
        {
            <p class="text-muted mb-0">No context fragments yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th scope="col">Type</th>
                            <th scope="col">Source</th>
                            <th scope="col">File</th>
                            <th scope="col">Text</th>
                            <th scope="col">Created</th>
                            <th scope="col" class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var fragment in Model.Analysis.ContextFragments)
                        {
                            <tr>
                                <td>@fragment.Type</td>
                                <td>@fragment.Source</td>
                                <td>@(fragment.FileName ?? "-")</td>
                                <td class="text-break">@fragment.Text</td>
                                <td>@fragment.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td class="text-end">
                                    <form method="post"
                                          asp-page-handler="DeleteContextFragment"
                                          asp-route-id="@Model.Analysis.Id"
                                          asp-route-fragmentId="@fragment.Id"
                                          class="d-inline">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}
