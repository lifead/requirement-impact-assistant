@page "/Analyses"
@model RequirementImpactAssistant.Web.Pages.Analyses.IndexModel
@{
    ViewData["Title"] = "Saved analyses";
}

<section class="py-4">
    <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
        <div>
            <h1 class="h2 mb-1">Saved analyses</h1>
            <p class="text-muted mb-0">Read-only list of stored analysis artifacts.</p>
        </div>
        <a class="btn btn-primary" asp-page="/Analyses/Create">New analysis</a>
    </div>

    @if (Model.Analyses.Count == 0)
    {
        <div class="border rounded p-4 bg-light">
            <p class="mb-0">No saved analyses yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th scope="col">Title</th>
                        <th scope="col">Status</th>
                        <th scope="col">Updated</th>
                        <th scope="col" class="text-end">Open</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var analysis in Model.Analyses)
                    {
                        <tr>
                            <td class="fw-medium">@analysis.Title</td>
                            <td>@analysis.Status</td>
                            <td>@analysis.UpdatedAt.ToLocalTime().ToString("g")</td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm"
                                   asp-page="/Analyses/Details"
                                   asp-route-id="@analysis.Id">
                                    Open
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>
